# .env.example — copy to `.env` (git-ignored) and adjust.
#
# These variables say WHERE to find the secret in the Keychain. They are the
# lookup config, NOT the secret. The secret value itself lives only in the
# macOS Keychain — never put it in this file or in `.env`.

# Keychain service (the keyring). The helpers default to "dev-keys" if unset.
KEYCHAIN_SERVICE=dev-keys

# Keychain account = the key name to look up.
KEYCHAIN_ACCOUNT=ANTHROPIC_API_KEY
